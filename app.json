{
  "expo": {
    "name": "Timgul",
    "slug": "Timgul",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "timgul",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.ddokonkwo.timgul",
      "adaptiveIcon": {
        "backgroundColor": "#f42a80",
        "foregroundImage": "./assets/images/logo-white.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "splash": {
        "image": "./assets/images/logo-white.png",
        "resizeMode": "contain",
        "backgroundColor": "#f42a80"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-white.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f42a80",
          "dark": {
            "backgroundColor": "#f42a80"
          }
        }
      ]
    ],
    "splash": {
      "image": "./assets/images/logo-white.png",
      "resizeMode": "contain",
      "backgroundColor": "#f42a80"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
